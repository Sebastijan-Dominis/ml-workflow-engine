@startuml build_interim_dataset.py Architecture
title build_interim_dataset.py Architecture

skinparam shadowing false
skinparam linetype ortho
skinparam packageStyle rectangle

skinparam package {
    BorderColor black
    BackgroundColor #f0f0f0
    Shadowing false
}   

package "Configs" {
    artifact interim_cfg as "Interim configs\n(configs/data/interim/...)"
}

component script as "build_interim_dataset.py"

package "Artifacts" {
    artifact raw_snapshot_metadata as "Raw Snapshot Metadata\n(data/raw/...)"
    artifact raw_data as "Raw Data\n(data/raw/...)"
    artifact metadata as "Interim Metadata\n(data/interim/...)"
    artifact interim_data as "Interim Dataset\n(data/interim/...)"
}

script ..> interim_cfg

script ..> raw_snapshot_metadata
script ..> raw_data

script --> metadata
script --> interim_data

legend right
..>   Config dependency / read
-->   Create
endlegend

@enduml