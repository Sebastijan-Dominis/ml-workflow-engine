@startuml build_processed_dataset.py Architecture
title build_processed_dataset.py Architecture
!include architecture-theme.puml
left to right direction

skinparam shadowing false
skinparam linetype ortho
skinparam packageStyle rectangle

package "Configs"<<Configs>> {
    artifact processed_cfg as "Processed configs\n(configs/data/processed/...)" <<config>>
}

component script as "build_processed_dataset.py" <<script>>

package "Input Artifacts"<<InputArtifacts>> {
    artifact interim_data as "Interim Data\n(data/interim/...)" <<artifact>>
    artifact interim_metadata as "Interim Metadata\n(data/interim/...)" <<artifact>>
}

package "Produced Artifacts"<<ProducedArtifacts>> {
    artifact metadata as "Processed Metadata\n(data/processed/...)" <<artifact>>
    artifact processed_data as "Processed Dataset\n(data/processed/...)" <<artifact>>
}

script ..> processed_cfg

script ..> interim_metadata 
script ..> interim_data

script --> metadata
script --> processed_data

legend right
..>   Config dependency / read
-->   Create
endlegend

@enduml