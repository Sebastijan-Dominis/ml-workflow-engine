@startuml build_interim_dataset.py Architecture
title build_interim_dataset.py Architecture
!include architecture-theme.puml
left to right direction

skinparam shadowing false
skinparam linetype ortho
skinparam packageStyle rectangle

package "Configs"<<Configs>> {
    artifact interim_cfg as "Interim configs\n(configs/data/interim/...)" <<config>>
}

component script as "build_interim_dataset.py" <<script>>

package "Input Artifacts"<<InputArtifacts>> {
    artifact raw_snapshot_metadata as "Raw Snapshot Metadata\n(data/raw/...)" <<artifact>>
    artifact raw_data as "Raw Data\n(data/raw/...)" <<artifact>>
}

package "Produced Artifacts"<<ProducedArtifacts>> {
    artifact metadata as "Interim Metadata\n(data/interim/...)" <<artifact>>
    artifact interim_data as "Interim Dataset\n(data/interim/...)" <<artifact>>
}

script ..> interim_cfg

script ..> raw_snapshot_metadata
script ..> raw_data

script --> metadata
script --> interim_data

legend right
..>   Config dependency / read
-->   Create
endlegend

@enduml