@startuml Orchestration Architecture
title Orchestration Architecture
!include architecture-theme.puml
left to right direction

skinparam packageStyle rectangle
skinparam shadowing false
skinparam linetype ortho

component run_all as "run_all_workflows.py" <<script>>
component exec_data as "execute_all_data_preprocessing.py" <<script>>
component freeze_all as "freeze_all_feature_sets.py" <<script>>
component exec_exp as "execute_experiment_with_latest.py" <<script>>
component exec_all_exp as "execute_all_experiments_with_latest.py" <<script>>

component register_raw as "register_raw_snapshot.py" <<script>>
component build_interim as "build_interim_dataset.py" <<script>>
component build_processed as "build_processed_dataset.py" <<script>>
component freeze as "freeze.py" <<script>>
component search as "search.py" <<script>>
component train as "train.py" <<script>>
component evaluate as "evaluate.py" <<script>>
component explain as "explain.py" <<script>>

run_all ==> exec_data
run_all ==> freeze_all
run_all ==> exec_all_exp
exec_all_exp --> exec_exp

exec_data ..> register_raw
exec_data ..> build_interim
exec_data ..> build_processed

freeze_all ..> freeze

exec_exp ..> search
exec_exp ..> train
exec_exp ..> evaluate
exec_exp ..> explain

legend right
==>   Orchestration trigger (one call)
--> Orchestration trigger (one or more calls)
..>   Workflow execution (one or more calls)
endlegend

@enduml