@startuml evaluate.py Architecture
title evaluate.py Architecture
left to right direction

skinparam shadowing false
skinparam linetype ortho
skinparam packageStyle rectangle

skinparam package {
    BorderColor black
    BackgroundColor #f0f0f0
    Shadowing false
}

component script as "evaluate.py"

package "Artifacts" {
    artifact feature_sets_metadata as "Feature Set(s) Metadata\n(feature_store/...)"
    artifact features as "Feature Set(s)\n(feature_store/...)"
    artifact processed_datasets as "Processed Dataset(s)\n(data/processed/...)"
    artifact input_schemas as "Input Schema(s)\n(feature_store/...)"
    artifact derived_schemas as "Derived Schema(s)\n(feature_store/...)\n(optional)"
    artifact training_metadata as "Training Metadata\n(experiments/.../training/...)"
    artifact training_runtime_info as "Training Runtime Info\n(experiments/.../training/...)"
    artifact model as "Trained Model\n(experiments/.../training/...)\n(optional)"
    artifact pipeline as "Trained Pipeline\n(experiments/.../training/...)\n(optional)"
    artifact evaluation_metadata as "Evaluation Metadata\n(experiments/.../evaluation/...)"
    artifact evaluation_runtime_info as "Evaluation Runtime Info\n(experiments/.../evaluation/...)"
    artifact evaluation_metrics as "Evaluation Metrics\n(experiments/.../evaluation/...)"
    artifact predictions_train as "Predictions - Training Set\n(experiments/.../evaluation/...)\n(optional)"
    artifact predictions_val as "Predictions - Validation Set\n(experiments/.../evaluation/...)\n(optional)"
    artifact predictions_test as "Predictions - Test Set\n(experiments/.../evaluation/...)\n(optional)"
}

script ..> feature_sets_metadata
script ..> features
script ..> processed_datasets
script ..> input_schemas
script ..> derived_schemas
script ..> model
script ..> pipeline
script ..> training_metadata
script ..> training_runtime_info

script --> evaluation_metadata
script --> evaluation_runtime_info
script --> evaluation_metrics
script --> predictions_train
script --> predictions_val
script --> predictions_test

legend right
..>   Config dependency / read
-->   Create
endlegend

@enduml