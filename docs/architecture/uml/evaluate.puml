@startuml evaluate.py Architecture
title evaluate.py Architecture
!include architecture-theme.puml
left to right direction

skinparam shadowing false
skinparam linetype ortho
skinparam packageStyle rectangle

component script as "evaluate.py" <<script>>

package "Input Artifacts"<<InputArtifacts>> {
    artifact feature_sets_metadata as "Feature Set(s) Metadata\n(feature_store/...)" <<artifact>>
    artifact feature_sets as "Feature Set(s)\n(feature_store/...)" <<artifact>>
    artifact processed_datasets as "Processed Dataset(s)\n(data/processed/...)" <<artifact>>
    artifact input_schemas as "Input Schema(s)\n(feature_store/...)" <<artifact>>
    artifact training_metadata as "Training Metadata\n(experiments/.../training/...)" <<artifact>>
    artifact training_runtime_info as "Training Runtime Info\n(experiments/.../training/...)" <<artifact>>
    artifact model as "Trained Model\n(experiments/.../training/...)\n(optional)" <<artifact>>
    artifact derived_schemas as "Derived Schema(s)\n(feature_store/...)\n(optional)" <<artifact_optional>>
    artifact pipeline as "Trained Pipeline\n(experiments/.../training/...)\n(optional)" <<artifact_optional>>
}

package "Produced Artifacts"<<ProducedArtifacts>> {
    artifact evaluation_metadata as "Evaluation Metadata\n(experiments/.../evaluation/...)" <<artifact>>
    artifact evaluation_runtime_info as "Evaluation Runtime Info\n(experiments/.../evaluation/...)" <<artifact>>
    artifact evaluation_metrics as "Evaluation Metrics\n(experiments/.../evaluation/...)" <<artifact>>
    artifact predictions_train as "Predictions - Training Set\n(experiments/.../evaluation/...)\n(optional)" <<artifact>>
    artifact predictions_val as "Predictions - Validation Set\n(experiments/.../evaluation/...)\n(optional)" <<artifact>>
    artifact predictions_test as "Predictions - Test Set\n(experiments/.../evaluation/...)\n(optional)" <<artifact>>

}

script ..> feature_sets_metadata
script ..> feature_sets
script ..> processed_datasets
script ..> input_schemas
script ..[#AAAAAA80]> derived_schemas
script ..> model
script ..[#AAAAAA80]> pipeline
script ..> training_metadata
script ..> training_runtime_info

script --> evaluation_metadata
script --> evaluation_runtime_info
script --> evaluation_metrics
script --> predictions_train
script --> predictions_val
script --> predictions_test

note right of derived_schemas
Only the feature sets that
create operators produce
derived schemas.
end note

note right of pipeline
Not all algorithms support/need
pipeline creation.
end note

note right of feature_sets
Merged and validated
at runtime - decoupled
from the models.
end note

note right of processed_datasets
Merged and validated at runtime;
used to create the target variable.
end note

legend right
..>   Config dependency / read
-->   Create
endlegend

@enduml