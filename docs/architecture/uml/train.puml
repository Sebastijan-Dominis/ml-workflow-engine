@startuml train.py Architecture
title train.py Architecture
!include architecture-theme.puml
left to right direction

skinparam shadowing false
skinparam linetype ortho
skinparam packageStyle rectangle

package "Configs"<<Configs>> {
    artifact global_cfg as "Global Default Configs\n(configs/defaults/)" <<config>>
    artifact algo_cfg as "Algorithm Default Configs\n(configs/defaults/)" <<config>>
    artifact model_spec as "Model Specs\n(configs/model_specs/...)" <<config>>
    artifact train_cfg as "Train Configs\n(configs/train/...)" <<config>>
    artifact env_cfg as "Environment Configs\n(configs/env/)\n(optional)" <<env>>
    artifact pipeline_cfg as "Pipeline Configs\n(configs/pipelines/...)\n(optional)" <<env>>
}

component script as "train.py" <<script>>

package "Input Artifacts"<<InputArtifacts>> {
    artifact feature_sets_metadata as "Feature Set(s) Metadata\n(feature_store/...)" <<artifact>>
    artifact feature_sets as "Feature Set(s)\n(feature_store/...)" <<artifact>>
    artifact input_schemas as "Input Schema(s)\n(feature_store/...)" <<artifact>>
    artifact processed_datasets as "Processed Dataset(s)\n(data/processed/...)" <<artifact>>
    artifact search_metadata as "Search Metadata\n(experiments/.../search/)" <<artifact>>
    artifact search_runtime_info as "Search Runtime Info\n(experiments/.../search/)" <<artifact>>
    artifact derived_schemas as "Derived Schema(s)\n(feature_store/...)\n(optional)" <<artifact_optional>>
}

package "Produced Artifacts"<<ProducedArtifacts>> {
    artifact training_metadata as "Training Metadata\n(experiments/.../training/...)" <<artifact>>
    artifact training_runtime_info as "Training Runtime Info\n(experiments/.../training/...)" <<artifact>>
    artifact training_metrics as "Training Metrics\n(experiments/.../training/...)" <<artifact>>
    artifact model as "Trained Model\n(experiments/.../training/...)" <<artifact>>
    artifact pipeline as "Trained Pipeline\n(experiments/.../training/...)\n(optional)" <<artifact_optional>>
}

script ..> global_cfg
script ..> algo_cfg
script ..> model_spec
script ..> train_cfg
script ..[#AAAAAA80]> env_cfg
script ..[#AAAAAA80]> pipeline_cfg

script ..> feature_sets_metadata
script ..> feature_sets
script ..> processed_datasets
script ..> input_schemas
script ..[#AAAAAA80]>  derived_schemas
script ..> search_metadata
script ..> search_runtime_info

script --> training_metadata
script --> training_runtime_info
script --> training_metrics
script --> model
script --[#AAAAAA80]> pipeline

note right of env_cfg
dev/test for quick iterations;
prod for final training runs.
end note

note right of pipeline_cfg
Used if defined in model specs;
creates the model's pipeline 
at runtime.
end note

note right of training_metrics
Only basic metrics
(more expected to be 
generated with evaluate.py)
end note

note right of pipeline
Not all algorithms support/need
pipeline creation.
end note

note right of derived_schemas
Only the feature sets that
create operators produce
derived schemas.
end note

note right of feature_sets
Merged and validated
at runtime - decoupled
from the models.
end note

note right of processed_datasets
Merged and validated at runtime;
used to create the target variable.
end note

legend right
..>   Config dependency / read
-->   Create
endlegend

@enduml