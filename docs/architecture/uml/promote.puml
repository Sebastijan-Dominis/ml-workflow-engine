@startuml promote.py Architecture
title promote.py Architecture
left to right direction

skinparam shadowing false
skinparam linetype ortho
skinparam packageStyle rectangle

skinparam package {
    BorderColor black
    BackgroundColor #f0f0f0
    Shadowing false
}

component script as "promote.py"

package "Configs" {
    artifact promotion_thresholds as "Promotion Thresholds\n(configs/promotion/)"
}

package "Artifacts" {
    artifact training_metadata as "Training Metadata\n(experiments/.../training/...)"
    artifact evaluation_metadata as "Evaluation Metadata\n(experiments/.../evaluation/...)"
    artifact explainability_metadata as "Explainability Metadata\n(experiments/.../explainability/...)"
    artifact evaluation_metrics as "Evaluation Metrics\n(experiments/.../evaluation/...)"
    artifact model_registry as "Model Registry\n(model_registry/)"
    artifact model_archive as "Model Archive\n(model_registry/)"
    artifact registry_diff as "Registry Diff\n(model_registry/runs/...)"
    artifact promotion_metadata as "Promotion Metadata\n(model_registry/runs/...)"
}

script ..> promotion_thresholds
script ..> training_metadata
script ..> evaluation_metadata
script ..> explainability_metadata
script ..> evaluation_metrics

script --> model_registry
script --> model_archive
script --> registry_diff
script --> promotion_metadata

legend right
..>   Config dependency / read
-->   Create
endlegend

@enduml