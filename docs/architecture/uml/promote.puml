@startuml promote.py Architecture
title promote.py Architecture
!include architecture-theme.puml
left to right direction

skinparam shadowing false
skinparam linetype ortho
skinparam packageStyle rectangle

component script as "promote.py" <<script>>

package "Configs"<<Configs>> {
    artifact promotion_thresholds as "Promotion Thresholds\n(configs/promotion/)" <<config>>
}

package "Input Artifacts"<<InputArtifacts>> {
    artifact training_metadata as "Training Metadata\n(experiments/.../training/...)" <<artifact>>
    artifact evaluation_metadata as "Evaluation Metadata\n(experiments/.../evaluation/...)" <<artifact>>
    artifact explainability_metadata as "Explainability Metadata\n(experiments/.../explainability/...)" <<artifact>>
    artifact evaluation_metrics as "Evaluation Metrics\n(experiments/.../evaluation/...)" <<artifact>>
}

package "Produced Artifacts"<<ProducedArtifacts>> {
    artifact model_registry as "Model Registry\n(model_registry/)" <<artifact>>
    artifact model_archive as "Model Archive\n(model_registry/)" <<artifact>>
    artifact registry_diff as "Registry Diff\n(model_registry/runs/...)" <<artifact>>
    artifact promotion_metadata as "Promotion Metadata\n(model_registry/runs/...)" <<artifact>>

}

script ..> promotion_thresholds
script ..> training_metadata
script ..> evaluation_metadata
script ..> explainability_metadata
script ..> evaluation_metrics

script --[#AAAAAA80]> model_registry
script ..> model_registry
script --[#AAAAAA80]> model_archive
script ..> model_archive
script --> registry_diff
script --> promotion_metadata

note right of model_registry
Reads and updates the model registry;
no update if the promotion is rejected.
end note

note right of model_archive
Reads and updates the model archive;
no update if the promotion is rejected.
end note

legend right
..>   Config dependency / read
-->   Create
endlegend

@enduml