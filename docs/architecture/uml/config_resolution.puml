    @startuml Config Resolution Architecture
    title Config Resolution Architecture
    top to bottom direction

    hide stereotype

    skinparam shadowing false
    skinparam linetype ortho

    skinparam component {
        BackgroundColor<<cli_args>> Orange
        BorderColor<<cli_args>> DarkOrange
    }

    skinparam artifact {
        BackgroundColor<<cfg>> MediumSlateBlue
        BorderColor<<cfg>> MediumPurple
    }

    skinparam artifact {
        BackgroundColor<<env_cfg>> MediumOrchid
        BorderColor<<env_cfg>> MediumPurple
    }

    skinparam artifact {
        BackgroundColor<<final_cfg>> LimeGreen
        BorderColor<<final_cfg>> Green
    }

    skinparam legend {
        BackgroundColor SlateGrey
        BorderColor Black
    }

    artifact global_cfg as "Global Default Configs\n(configs/defaults/)" <<cfg>>
    artifact algo_cfg as "Algorithm Default Configs\n(configs/defaults/)" <<cfg>>
    artifact model_spec as "Model Specs\n(configs/model_specs/...)" <<cfg>>
    artifact stage_cfg as "Search/Train Configs\n(configs/search/...|configs/train/...)" <<cfg>>
    artifact env_cfg as "Environment Configs\n(configs/env/)\n(optional)" <<env_cfg>>

    artifact final_cfg as "Resolved Runtime Config" <<final_cfg>>

    global_cfg --> algo_cfg : overrides
    algo_cfg --> model_spec : overrides
    model_spec --> stage_cfg : overrides
    stage_cfg --> env_cfg : overrides\n(optional)
    env_cfg --> final_cfg : final merge

    component cli_args as "CLI Arguments" <<cli_args>>

    cli_args ..> model_spec : selects
    cli_args ..> stage_cfg : selects
    cli_args ..> env_cfg : enables\n(optional)
    cli_args-[hidden]->env_cfg
    cli_args-[hidden]->env_cfg

    legend right
    -->   Override precedence (lower → higher)
    ..>   Selection via CLI
    endlegend

    @enduml